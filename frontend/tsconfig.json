{
  "typeRoots": ["./src/types", "./node_modules/@types"],
  "include": ["src", "src/types/images.d.ts"],
  "compilerOptions": {
    "jsx": "react",
    "typeRoots": ["./types", "./node_modules/@types"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "types": ["node"],
    "skipLibCheck": true
  }
}
